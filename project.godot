; Engine configuration file for Chalk & Chance
; A Pokemon-style 2D teacher-simulation game. Design source: GAME_CONCEPT.md
; Godot 4.6.3

config_version=5

[application]

config/name="Chalk & Chance"
config/description="A Pokemon-style 2D teacher-simulation game where classroom encounters are read-act-observe dialogues against LLM-driven students. See GAME_CONCEPT.md."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

Items="*res://autoload/Items.gd"
GameState="*res://autoload/GameState.gd"
Game="*res://autoload/Game.gd"
SceneRouter="*res://autoload/SceneRouter.gd"
LLMClient="*res://autoload/LLMClient.gd"
TTSClient="*res://autoload/TTSClient.gd"
Auth="*res://autoload/Auth.gd"
Telemetry="*res://autoload/Telemetry.gd"
Competency="*res://autoload/Competency.gd"
Sfx="*res://autoload/Sfx.gd"
VoiceInput="*res://autoload/VoiceInput.gd"

[gui]

theme/custom="res://ui/theme.tres"

[display]

window/size/viewport_width=960
window/size/viewport_height=540
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"
window/stretch/scale_mode="integer"

[rendering]

textures/canvas_textures/default_texture_filter=0
